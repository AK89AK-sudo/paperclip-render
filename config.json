{
  "$meta": {
    "version": 1,
    "updatedAt": "2026-03-20T00:00:00.000Z",
    "source": "configure"
  },
  "database": {
    "mode": "postgres"
  },
  "logging": {
    "mode": "cloud"
  },
  "server": {
    "deploymentMode": "authenticated",
    "exposure": "public",
    "host": "0.0.0.0",
    "port": 3100,
    "allowedHostnames": [
      "bravovalue.com",
      "www.bravovalue.com",
      "paperclip-l1cb.onrender.com"
    ],
    "serveUi": true
  },
  "auth": {
    "baseUrlMode": "explicit",
    "publicBaseUrl": "https://www.bravovalue.com",
    "disableSignUp": false
  },
  "storage": {
    "provider": "local_disk",
    "localDisk": {
      "baseDir": "/data/storage"
    }
  },
  "secrets": {
    "provider": "local_encrypted",
    "strictMode": false
  }
}
